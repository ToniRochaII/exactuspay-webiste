# ============================================================
# SIMPLIFIED PROCESS PERIOD VIEW
# ============================================================

@method_decorator(login_required, name="dispatch")
class PayrollPeriodProcessView(View):
    
    def post(self, request, country_slug, company_id, payroll_id, period_id):
        period = get_object_or_404(
            PayrollPeriod, 
            pk=period_id, 
            payroll_id=payroll_id, 
            payroll__company_id=company_id
        )

        # Start Execution Log
        execution_log = PayrollExecutionLog.objects.create(
            period=period, 
            execution_type="calculation", 
            status="started",
            input_data={"period_id": period_id, "country": country_slug}, 
            executed_by=request.user
        )

        try:
            # Mark Period as Processing
            period.mark_as_processing(request.user)
            
            # Get Employees
            employees = period.get_eligible_employees()
            if not employees.exists():
                raise ValueError("No eligible employees found for this period.")

            # Simple processing
            with transaction.atomic():
                # Clear old results
                PayrollResult.objects.filter(period=period).delete()
                
                results_to_create = []
                
                for emp in employees:
                    # Simple calculation for now
                    results_to_create.append(PayrollResult(
                        period=period,
                        employee=emp,
                        gross_pay=Decimal('0.00'),
                        net_pay=Decimal('0.00'),
                        total_tax=Decimal('0.00'),
                        total_deductions=Decimal('0.00'),
                        details={}
                    ))

                # Bulk Save
                PayrollResult.objects.bulk_create(results_to_create)
                
                # Update Period
                period.total_gross = Decimal('0.00')
                period.total_net = Decimal('0.00')
                period.total_tax = Decimal('0.00')
                
                period.mark_as_completed(results_payload={
                    "employee_count": len(results_to_create),
                    "total_net": "0.00",
                    "total_gross": "0.00"
                })

            # Log Success
            execution_log.mark_completed({
                "processed_count": len(results_to_create), 
                "country": country_slug,
                "success": True
            })

            return JsonResponse({
                "success": True,
                "message": f"Successfully processed {len(results_to_create)} employees.",
                "redirect_url": reverse('payroll:period_detail', 
                                       args=[country_slug, company_id, payroll_id, period_id])
            })

        except Exception as e:
            import traceback
            traceback.print_exc()
            execution_log.mark_failed(str(e))
            period.status = PeriodStatus.PENDING
            period.save()
            return JsonResponse({
                "success": False, 
                "error": f"Processing error: {str(e)}"
            }, status=500)


# ============================================================
# APPROVE PERIOD
# ============================================================

@login_required
@require_POST
def approve_period(request, country_slug, company_id, payroll_id, period_id):
    period = get_object_or_404(
        PayrollPeriod, 
        pk=period_id, 
        payroll_id=payroll_id, 
        payroll__company_id=company_id
    )

    if period.status != PeriodStatus.PENDING:
        messages.error(request, "Only pending periods can be approved.")
        return redirect('payroll:period_detail', 
                       country_slug=country_slug,
                       company_id=company_id,
                       payroll_id=payroll_id,
                       pk=period_id)

    try:
        with transaction.atomic():
            # Get eligible employees
            employees = period.get_eligible_employees()
            
            if not employees.exists():
                messages.error(request, "No eligible employees found.")
                return redirect('payroll:period_detail',
                               country_slug=country_slug,
                               company_id=company_id,
                               payroll_id=payroll_id,
                               pk=period_id)

            # Clear old results
            PayrollResult.objects.filter(period=period).delete()
            
            results_to_create = []
            
            for emp in employees:
                results_to_create.append(PayrollResult(
                    period=period,
                    employee=emp,
                    gross_pay=Decimal('0.00'),
                    net_pay=Decimal('0.00'),
                    total_tax=Decimal('0.00'),
                    total_deductions=Decimal('0.00'),
                    details={}
                ))
            
            if not results_to_create:
                raise ValueError("No employees were successfully processed")
            
            # Bulk save
            PayrollResult.objects.bulk_create(results_to_create)
            
            # Update period
            period.total_gross = Decimal('0.00')
            period.total_net = Decimal('0.00')
            period.total_tax = Decimal('0.00')
            period.mark_as_completed({
                "employee_count": len(results_to_create),
                "total_net": "0.00",
                "total_gross": "0.00"
            })

            messages.success(
                request, 
                f"Period approved successfully. Processed {len(results_to_create)} employees."
            )

    except Exception as e:
        logger = logging.getLogger(__name__)
        logger.error(f"Error approving period: {e}")
        messages.error(request, f"Error approving period: {str(e)}")

    return redirect('payroll:period_detail',
                   country_slug=country_slug,
                   company_id=company_id,
                   payroll_id=payroll_id,
                   pk=period_id)


# ============================================================
# EXPORT VIEW
# ============================================================

class PayrollPeriodExportView(View):
    @method_decorator(login_required)
    def get(self, request, country_slug, company_id, payroll_id, period_id):
        period = get_object_or_404(
            PayrollPeriod, 
            pk=period_id, 
            payroll_id=payroll_id, 
            payroll__company_id=company_id
        )

        results = PayrollResult.objects.filter(period=period).select_related('employee')
        
        if not results.exists():
            return HttpResponse("No results found to export.", content_type="text/plain")

        filename = f"GTN_Report_{period.name.replace(' ', '_')}.csv"
        response = HttpResponse(content_type='text/csv')
        response['Content-Disposition'] = f'attachment; filename="{filename}"'

        writer = csv.writer(response)
        
        # Simple headers
        headers = ['Employee ID', 'Name', 'Gross Pay', 'Net Pay', 'Total Tax']
        writer.writerow(headers)
        
        # Simple data
        for res in results:
            row = [
                res.employee.id,
                f"{res.employee.employee_name} {res.employee.employee_surname}",
                res.gross_pay,
                res.net_pay,
                res.total_tax
            ]
            writer.writerow(row)

        return response


# ============================================================
# AJAX UTILITY VIEWS
# ============================================================

@login_required
def get_next_period_number(request, payroll_id):
    payroll = get_object_or_404(Payroll, pk=payroll_id)
    last_period = PayrollPeriod.objects.filter(payroll=payroll).order_by('period_number').last()
    next_number = last_period.period_number + 1 if last_period else 1
    return JsonResponse({
        'next_period_number': next_number,
        'payroll_id': payroll_id,
        'fiscal_year': payroll.fiscal_year
    })

@login_required
@require_POST
def lock_payroll(request, country_slug, company_id, payroll_id):
    payroll = get_object_or_404(Payroll, pk=payroll_id, company_id=company_id)
    try:
        payroll.lock(request.user)
        return JsonResponse({
            'success': True,
            'message': f'Payroll FY{payroll.fiscal_year} locked successfully',
            'status': payroll.status,
            'locked_at': payroll.locked_at.isoformat() if payroll.locked_at else None
        })
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)

@login_required
@require_POST
def unlock_payroll(request, country_slug, company_id, payroll_id):
    payroll = get_object_or_404(Payroll, pk=payroll_id, company_id=company_id)
    try:
        payroll.unlock()
        return JsonResponse({
            'success': True,
            'message': f'Payroll FY{payroll.fiscal_year} unlocked successfully',
            'status': payroll.status,
            'locked_at': None
        })
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)

@login_required
@require_POST
def lock_period(request, country_slug, company_id, payroll_id, period_id):
    period = get_object_or_404(PayrollPeriod, pk=period_id, payroll_id=payroll_id)
    try:
        period.lock()
        return JsonResponse({
            'success': True,
            'message': f'Period {period.name} locked successfully',
            'status': period.status
        })
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)

@login_required
@require_POST
def unlock_period(request, country_slug, company_id, payroll_id, period_id):
    period = get_object_or_404(PayrollPeriod, pk=period_id, payroll_id=payroll_id)
    try:
        period.unlock()
        return JsonResponse({
            'success': True,
            'message': f'Period {period.name} unlocked successfully',
            'status': period.status
        })
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)

@login_required
def payroll_summary_api(request, payroll_id):
    payroll = get_object_or_404(Payroll, pk=payroll_id)
    summary = payroll.get_periods_summary()
    return JsonResponse({
        'success': True,
        'summary': summary,
        'payroll': {
            'id': payroll.pk,
            'fiscal_year': payroll.fiscal_year,
            'status': payroll.status,
            'status_display': payroll.get_status_display(),
            'is_editable': payroll.is_editable,
            'is_deletable': payroll.is_deletable,
        }
    })


# ============================================================
# RESET LOGIC
# ============================================================

@login_required
@role_required("EXEC", "ADMIN", "COMPLIANCE", "BILLING", "IMPLEMENTATION",
               "OPERATION", "DIRECTOR", "MANAGER", "SPECIALIST", "FINANCE")
@require_http_methods(["GET", "POST"])
def payroll_reset_confirm(request, country_slug, company_id, payroll_id):
    payroll = get_object_or_404(
        Payroll, 
        pk=payroll_id, 
        company_id=company_id
    )

    if request.method == "POST":
        try:
            with transaction.atomic():
                payroll.status = PayrollStatus.RUNNING
                payroll.save()
                
                periods = PayrollPeriod.objects.filter(payroll=payroll)
                updated_count = periods.update(
                    status=PeriodStatus.PENDING,
                    total_gross=0,
                    total_net=0,
                    total_tax=0,
                    total_amount=0
                )
                
                PayrollResult.objects.filter(period__payroll=payroll).delete()
                
                messages.success(
                    request, 
                    f"Successfully reset Payroll FY{payroll.fiscal_year}. "
                    f"{updated_count} periods reverted to Pending."
                )
                
                return redirect('payroll:payroll_detail', country_slug=country_slug, company_id=company_id, pk=payroll.pk)

        except Exception as e:
            messages.error(request, f"Error resetting payroll: {str(e)}")

    context = {
        'payroll': payroll,
        'period_count': payroll.periods.count(),
        'country_slug': country_slug,
        'company_id': company_id,
    }
    return render(request, 'payroll/payroll_reset_confirm.html', context)


@login_required
@role_required("EXEC", "ADMIN", "COMPLIANCE", "BILLING", "IMPLEMENTATION",
               "OPERATION", "DIRECTOR", "MANAGER", "SPECIALIST", "FINANCE")
@require_http_methods(["GET", "POST"])
def payroll_period_reset_confirm(request, country_slug, company_id, payroll_id, period_id):
    period = get_object_or_404(
        PayrollPeriod, 
        pk=period_id, 
        payroll_id=payroll_id, 
        payroll__company_id=company_id
    )

    if request.method == "POST":
        try:
            with transaction.atomic():
                deleted_count, _ = PayrollResult.objects.filter(period=period).delete()
                
                PayrollPeriod.objects.filter(pk=period.pk).update(
                    status=PeriodStatus.PENDING,
                    total_gross=Decimal("0.00"),
                    total_net=Decimal("0.00"),
                    total_tax=Decimal("0.00"),
                    total_amount=Decimal("0.00")
                )

                messages.success(
                    request, 
                    f"Period '{period.name}' successfully forced to 'Pending'. "
                    f"Cleared {deleted_count} calculation records."
                )
                
                return redirect('payroll:period_detail', country_slug=country_slug, company_id=company_id, payroll_id=payroll_id, pk=period.pk)

        except Exception as e:
            messages.error(request, f"Error resetting period: {str(e)}")
            logger = logging.getLogger(__name__)
            logger.error(f"Reset failed for period {period_id}: {e}")

    context = {
        'period': period,
        'country_slug': country_slug,
        'company_id': company_id,
        'payroll_id': payroll_id,
    }
    return render(request, 'payroll/period_reset_confirm.html', context)