msgid "Careers"
msgstr "Carreras"

#: templates/home/features.html:190
msgid "Security"
msgstr "Seguridad"

#: templates/home/features.html:191
msgid "Contact"
msgstr "Contacto"

#: templates/home/features.html:202
msgid "All rights reserved."
msgstr "Todos los derechos reservados."

#: templates/home/features.html:203
msgid "GDPR Compliant | SOC 2 Type II Certified | ISO 27001"
msgstr "Cumplimiento GDPR | Certificado SOC 2 Tipo II | ISO 27001"

#: templates/home/index.html:8
msgid "ExactusPay | Global Payroll Intelligence Platform"
msgstr "ExactusPay | Plataforma de Inteligencia para Nómina Global"

#: templates/home/index.html:27 (Home page specific)
msgid "Intelligent Global Payroll Platform"
msgstr "Plataforma Inteligente de Nómina Global"

#: templates/home/index.html:29
msgid ""
"Streamline global workforce management with AI-driven compliance, real-time insights, and seamless payroll processing across 50+ countries."
msgstr ""
"Optimice la gestión global de la fuerza laboral con cumplimiento impulsado por IA, información en tiempo real y procesamiento continuo de nómina en más de 40 países."

#: templates/home/index.html:33
msgid "Watch Demo"
msgstr "Ver demostración"

#: templates/home/index.html:38
msgid "Accuracy Rate"
msgstr "Tasa de Precisión"

#: templates/home/index.html:41
msgid "Countries"
msgstr "Países"

#: templates/home/index.html:44
msgid "Support"
msgstr "Soporte"

#: templates/home/index.html:47
msgid "Compliance"
msgstr "Cumplimiento"

#: templates/home/index.html:54 (Features section)
msgid "Powerful Features"
msgstr "Características Poderosas"

#: templates/home/index.html:55
msgid "Designed for Global Scale"
msgstr "Diseñado para Escala Global"

#: templates/home/index.html:56
msgid "Everything you need to manage complex global payroll operations with confidence"
msgstr "Todo lo que necesita para gestionar operaciones complejas de nómina global con confianza"

#: templates/home/index.html:61
msgid "AI-Powered Compliance"
msgstr "Cumplimiento con IA"

#: templates/home/index.html:62
msgid "Automated regulatory updates and risk assessment across all jurisdictions with machine learning algorithms."
msgstr "Actualizaciones regulatorias automatizadas y evaluación de riesgos en todas las jurisdicciones con algoritmos de aprendizaje automático."

#: templates/home/index.html:66
msgid "Real-time Analytics"
msgstr "Análisis en Tiempo Real"

#: templates/home/index.html:67
msgid "Comprehensive dashboards with live insights into payroll costs, compliance status, and operational metrics."
msgstr "Paneles completos con información en vivo sobre costos de nómina, estado de cumplimiento y métricas operativas."

#: templates/home/index.html:71
msgid "Instant Processing"
msgstr "Procesamiento Instantáneo"

#: templates/home/index.html:72
msgid "Batch process thousands of payments across different currencies and banking systems simultaneously."
msgstr "Procese en lote miles de pagos en diferentes monedas y sistemas bancarios simultáneamente."

#: templates/home/index.html:76
msgid "Enterprise Security"
msgstr "Seguridad Empresarial"

#: templates/home/index.html:77
msgid "Bank-grade encryption, multi-factor authentication, and SOC 2 Type II certified infrastructure."
msgstr "Cifrado de nivel bancario, autenticación multifactor e infraestructura certificada SOC 2 Tipo II."

#: templates/home/index.html:81
msgid "Global Coverage"
msgstr "Cobertura Global"

#: templates/home/index.html:82
msgid "Seamless payroll processing across 50+ countries with local compliance and tax expertise built-in."
msgstr "Procesamiento continuo de nómina en más de 40 países con cumplimiento local y experiencia fiscal integrada."

#: templates/home/index.html:86
msgid "Audit Trail"
msgstr "Pista de Auditoría"

#: templates/home/index.html:87
msgid "Complete transparency with immutable records for every transaction and compliance verification."
msgstr "Transparencia completa con registros inmutables para cada transacción y verificación de cumplimiento."

#: templates/home/index.html:96 (Platform section)
msgid "Unified Platform"
msgstr "Plataforma Unificada"

#: templates/home/index.html:98
msgid "Everything in One Dashboard"
msgstr "Todo en Un Panel"

#: templates/home/index.html:99
msgid "Manage your entire global payroll operation from a single, intuitive interface with real-time data and actionable insights."
msgstr "Gestione toda su operación global de nómina desde una única interfaz intuitiva con datos en tiempo real e información procesable."

#: templates/home/index.html:105
msgid "Monitor payroll costs, compliance status, and operational metrics across all regions with live dashboards."
msgstr "Monitoree costos de nómina, estado de cumplimiento y métricas operativas en todas las regiones con paneles en vivo."

#: templates/home/index.html:109
msgid "Process payments in 50+ currencies with automated forex management and optimal exchange rates."
