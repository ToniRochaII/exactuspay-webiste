msgstr ""
"Il monitoraggio operativo e i controlli di sicurezza aiutano a rilevare le "
"anomalie precocemente e ridurre i tempi di risposta."

#: home/templates/home/security.html:1148
msgid "Compliance & Sovereignty"
msgstr "Conformità e sovranità"

#: home/templates/home/security.html:1149
msgid "Aligned to international standards"
msgstr "Allineato agli standard internazionali"

#: home/templates/home/security.html:1150
