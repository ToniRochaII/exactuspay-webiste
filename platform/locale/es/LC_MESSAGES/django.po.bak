msgstr "Mínimo 8 caracteres con mayúsculas, minúsculas y números"

#: Exactus/accounts/templates/auth/register.html:221
msgid "Confirm Password"
msgstr "Confirmar Contraseña"

#: Exactus/accounts/templates/auth/register.html:227
msgid "Confirm password"
msgstr "Confirmar contraseña"

#: Exactus/accounts/templates/auth/register.html:247
