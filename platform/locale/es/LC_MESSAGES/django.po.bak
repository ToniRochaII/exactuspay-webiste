msgstr "country_code, company_code, trade_name, legal_name"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "country_code must match ISO2 codes (e.g., US, GB, FR)"
msgstr "country_code debe coincidir con códigos ISO2 (ej.: US, GB, FR)"

#: Exactus/company/templates/companies/upload_companies.html:1
