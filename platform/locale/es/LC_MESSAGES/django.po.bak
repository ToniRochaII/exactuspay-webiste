# ===============================
#: Exactus/accounts/templates/auth/password_reset.html:20
#: Exactus/accounts/templates/auth/password_reset_complete.html:25
#: Exactus/accounts/templates/auth/password_reset_confirm.html:20
#: Exactus/accounts/templates/auth/password_reset_done.html:20
msgid "Authentication"
msgstr "Autenticación"

#: Exactus/accounts/templates/auth/password_reset.html:35
#: Exactus/accounts/templates/auth/password_reset.html:43
#: Exactus/accounts/templates/auth/password_reset_confirm.html:39
#: Exactus/accounts/templates/auth/register.html:38
#: Exactus/accounts/templates/auth/register.html:51
msgid "Close"
msgstr "Cerrar"

#: Exactus/accounts/templates/auth/password_reset.html:52
msgid "Request Password Reset"
msgstr "Solicitar restablecimiento de contraseña"

#: Exactus/accounts/templates/auth/password_reset.html:61
msgid ""
"Enter your email address and we'll send you a link to reset your password."
msgstr ""
"Ingrese su dirección de correo electrónico y le enviaremos un enlace para "
"restablecer su contraseña."

#: Exactus/accounts/templates/auth/password_reset.html:71
#: Exactus/accounts/templates/auth/register.html:111
#: Exactus/accounts/templates/profile/unified_profile.html:133
msgid "Email Address"
msgstr "Dirección de correo electrónico"

#: Exactus/accounts/templates/auth/password_reset.html:81
msgid "Enter your registered email"
msgstr "Ingrese su correo electrónico registrado"

#: Exactus/accounts/templates/auth/password_reset.html:93
msgid "You'll receive a password reset link at this email address."
msgstr "Recibirá un enlace de restablecimiento de contraseña en este correo."

#: Exactus/accounts/templates/auth/password_reset.html:100
msgid "Send Reset Link"
msgstr "Enviar enlace de restablecimiento"

#: Exactus/accounts/templates/auth/password_reset.html:112
#: Exactus/accounts/templates/auth/password_reset_confirm.html:174
msgid "Remember your password?"
msgstr "¿Recuerda su contraseña?"

#: Exactus/accounts/templates/auth/password_reset.html:113
#: Exactus/accounts/templates/auth/password_reset_confirm.html:175
msgid "Sign in here"
msgstr "Inicie sesión aquí"

#: Exactus/accounts/templates/auth/password_reset.html:116
msgid "Need help?"
msgstr "¿Necesita ayuda?"

#: Exactus/accounts/templates/auth/password_reset.html:117
msgid "Contact support"
msgstr "Contactar soporte"

#: Exactus/accounts/templates/auth/password_reset.html:127
msgid ""
"For security reasons, the password reset link will expire in 24 hours and "
"can only be used once."
msgstr ""
"Por razones de seguridad, el enlace de restablecimiento de contraseña "
"expirará en 24 horas y solo podrá usarse una vez."

#: Exactus/accounts/templates/auth/password_reset.html:148
msgid "Sending Reset Link..."
msgstr "Enviando enlace de restablecimiento..."

# ===============================
# Password Reset Flow
# ===============================
#: Exactus/accounts/templates/auth/password_reset_complete.html:6
#: Exactus/accounts/templates/auth/password_reset_complete.html:16
msgid "Password Reset Complete"
msgstr "Restablecimiento de Contraseña Completado"

#: Exactus/accounts/templates/auth/password_reset_complete.html:28
msgid "Reset Complete"
msgstr "Restablecimiento Completado"

#: Exactus/accounts/templates/auth/password_reset_complete.html:42
msgid "Password Reset Successful"
msgstr "Contraseña Restablecida con Éxito"

#: Exactus/accounts/templates/auth/password_reset_complete.html:45
msgid ""
"Your password has been successfully reset. You can now log in with your new "
"password."
msgstr ""
"Su contraseña ha sido restablecida con éxito. Ahora puede iniciar sesión con "
"su nueva contraseña."

#: Exactus/accounts/templates/auth/password_reset_complete.html:52
msgid "Security Tip"
msgstr "Consejo de Seguridad"

#: Exactus/accounts/templates/auth/password_reset_complete.html:54
msgid ""
"For security, please don't share your password and make sure to log out "
"after each session."
msgstr ""
"Por seguridad, no comparta su contraseña y asegúrese de cerrar sesión "
"después de cada sesión."

#: Exactus/accounts/templates/auth/password_reset_complete.html:63
msgid "Sign In Now"
msgstr "Iniciar Sesión Ahora"

#: Exactus/accounts/templates/auth/password_reset_complete.html:77
msgid "Need Help?"
msgstr "¿Necesita Ayuda?"

#: Exactus/accounts/templates/auth/password_reset_complete.html:80
msgid "Contact our support team if you're having trouble logging in."
msgstr ""
"Póngase en contacto con nuestro equipo de soporte si tiene problemas para "
"iniciar sesión."

#: Exactus/accounts/templates/auth/password_reset_complete.html:82
msgid "Get Help"
msgstr "Obtener Ayuda"

#: Exactus/accounts/templates/auth/password_reset_complete.html:92
msgid "Account Security"
msgstr "Seguridad de la Cuenta"

#: Exactus/accounts/templates/auth/password_reset_complete.html:95
msgid "Review your account security settings."
msgstr "Revise la configuración de seguridad de su cuenta."

#: Exactus/accounts/templates/auth/password_reset_complete.html:97
msgid "Security Settings"
msgstr "Configuración de Seguridad"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:6
#: Exactus/accounts/templates/auth/password_reset_confirm.html:15
#: Exactus/accounts/templates/auth/password_reset_confirm.html:21
msgid "Set New Password"
msgstr "Establecer Nueva Contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:30
#: Exactus/accounts/templates/auth/register.html:29
msgid "Please correct the following errors:"
msgstr "Por favor, corrija los siguientes errores:"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:49
msgid "Invalid Reset Link"
msgstr "Enlace de Restablecimiento Inválido"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:52
msgid "The password reset link is invalid or has expired."
msgstr "El enlace de restablecimiento de contraseña es inválido o ha expirado."

#: Exactus/accounts/templates/auth/password_reset_confirm.html:53
#: Exactus/accounts/templates/auth/password_reset_confirm.html:192
msgid "Please request a new password reset link."
msgstr "Por favor, solicite un nuevo enlace de restablecimiento de contraseña."

#: Exactus/accounts/templates/auth/password_reset_confirm.html:63
msgid "Create New Password"
msgstr "Crear Nueva Contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:71
msgid "Please enter your new password twice to confirm it."
msgstr "Ingrese su nueva contraseña dos veces para confirmarla."

#: Exactus/accounts/templates/auth/password_reset_confirm.html:80
msgid "New Password"
msgstr "Nueva Contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:88
msgid "Enter new password"
msgstr "Ingrese nueva contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:98
msgid "Must be at least 8 characters with uppercase, lowercase, and numbers."
msgstr ""
"Debe tener al menos 8 caracteres con mayúsculas, minúsculas y números."

#: Exactus/accounts/templates/auth/password_reset_confirm.html:111
#: Exactus/accounts/templates/auth/password_reset_confirm.html:248
#: Exactus/accounts/templates/auth/register.html:215
#: Exactus/accounts/templates/auth/register.html:425
msgid "Password strength"
msgstr "Fortaleza de la contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:118
msgid "Confirm New Password"
msgstr "Confirmar Nueva Contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:126
msgid "Confirm new password"
msgstr "Confirmar nueva contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:149
msgid "Password Requirements"
msgstr "Requisitos de Contraseña"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:152
msgid "At least 8 characters long"
msgstr "Al menos 8 caracteres"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:153
msgid "Include uppercase and lowercase letters"
msgstr "Incluir letras mayúsculas y minúsculas"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:154
msgid "Include at least one number"
msgstr "Incluir al menos un número"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:155
msgid "Include special characters (optional but recommended)"
msgstr "Incluir caracteres especiales (opcional pero recomendado)"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:189
msgid "Link Expired"
msgstr "Enlace Expirado"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:191
msgid "This password reset link has expired or is no longer valid."
msgstr "Este enlace de restablecimiento de contraseña ha expirado o ya no es válido."

#: Exactus/accounts/templates/auth/password_reset_confirm.html:198
msgid "Request New Reset Link"
msgstr "Solicitar Nuevo Enlace de Restablecimiento"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:202
#: Exactus/accounts/templates/auth/password_reset_done.html:58
msgid "Back to Login"
msgstr "Volver al Inicio de Sesión"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:255
#: Exactus/accounts/templates/auth/register.html:432
msgid "Weak"
msgstr "Débil"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:259
#: Exactus/accounts/templates/auth/register.html:436
msgid "Fair"
msgstr "Aceptable"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:263
#: Exactus/accounts/templates/auth/register.html:440
msgid "Good"
msgstr "Buena"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:267
#: Exactus/accounts/templates/auth/register.html:444
msgid "Strong"
msgstr "Fuerte"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:287
#: Exactus/accounts/templates/auth/register.html:465
msgid "Passwords do not match"
msgstr "Las contraseñas no coinciden"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:292
#: Exactus/accounts/templates/auth/register.html:472
msgid "Passwords match"
msgstr "Las contraseñas coinciden"

#: Exactus/accounts/templates/auth/password_reset_confirm.html:314
msgid "Resetting Password..."
msgstr "Restableciendo contraseña..."

#: Exactus/accounts/templates/auth/password_reset_done.html:6
#: Exactus/accounts/templates/auth/password_reset_done.html:21
msgid "Reset Email Sent"
msgstr "Correo de Restablecimiento Enviado"

#: Exactus/accounts/templates/auth/password_reset_done.html:15
msgid "Check Your Email"
msgstr "Revise su Correo Electrónico"

#: Exactus/accounts/templates/auth/password_reset_done.html:34
msgid "Reset Link Sent"
msgstr "Enlace de Restablecimiento Enviado"

#: Exactus/accounts/templates/auth/password_reset_done.html:37
msgid "We've sent password reset instructions to your email address."
msgstr ""
"Hemos enviado instrucciones de restablecimiento de contraseña a su correo "
"electrónico."

#: Exactus/accounts/templates/auth/password_reset_done.html:38
msgid "Please check your inbox and follow the link to reset your password."
msgstr ""
"Por favor, revise su bandeja de entrada y siga el enlace para restablecer "
"su contraseña."

#: Exactus/accounts/templates/auth/password_reset_done.html:45
msgid "Didn't receive the email?"
msgstr "¿No recibió el correo?"

#: Exactus/accounts/templates/auth/password_reset_done.html:47
msgid "Check your spam or junk folder"
msgstr "Revise su carpeta de spam o correo no deseado"

#: Exactus/accounts/templates/auth/password_reset_done.html:48
msgid "Verify you entered the correct email address"
msgstr "Verifique que ingresó el correo correcto"

#: Exactus/accounts/templates/auth/password_reset_done.html:49
msgid "Wait a few minutes and try again"
msgstr "Espere unos minutos e intente de nuevo"

#: Exactus/accounts/templates/auth/password_reset_done.html:62
msgid "Try Again"
msgstr "Intentar de Nuevo"

#: Exactus/accounts/templates/auth/password_reset_done.html:70
msgid "Need immediate assistance?"
msgstr "¿Necesita asistencia inmediata?"

#: Exactus/accounts/templates/auth/password_reset_done.html:71
msgid "Contact our support team"
msgstr "Contacte a nuestro equipo de soporte"

