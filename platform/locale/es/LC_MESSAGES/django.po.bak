msgstr "Requisitos del CSV"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "File must be a .csv (comma-separated values)"
msgstr "El archivo debe ser .csv (valores separados por comas)"

#: Exactus/company/templates/companies/upload_companies.html:1
