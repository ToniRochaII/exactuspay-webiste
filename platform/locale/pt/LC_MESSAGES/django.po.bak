# JS strings
msgid "Processing..."
msgstr "A processar..."

msgid "Action Failed:"
msgstr "Ação falhou:"

msgid "Server Error"
msgstr "Erro do servidor"

msgid "Operation failed"
msgstr "A operação falhou"

msgid "Start Payroll Calculation for this period?"
msgstr "Iniciar o cálculo da folha para este período?"

msgid "Send for Approval? This will lock the period from further calculations."
msgstr ""
"Enviar para aprovação? Isto irá bloquear o período para novos cálculos."

msgid ""
"Authorize Payroll? This action is final and marks the period as Completed."
msgstr "Autorizar a folha? Esta ação é final e marca o período como Concluído."

msgid ""
"Reject Payroll? This will return the period to Pending and delete current "
"calculations."
msgstr ""
"Rejeitar a folha? Isto devolverá o período para Pendente e apagará os "
"cálculos atuais."

