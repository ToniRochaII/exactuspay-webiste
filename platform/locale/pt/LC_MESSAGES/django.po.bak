msgstr "Todos"

msgid "Reset Period - %(period_name)s"
msgstr "Repor Período - %(period_name)s"

msgid "Confirm Period Reset"
msgstr "Confirmar Reposição do Período"

msgid "Reset %(period_name)s?"
msgstr "Repor %(period_name)s?"

msgid "Current Status:"
msgstr "Estado Atual:"

msgid "What will happen:"
msgstr "O que vai acontecer:"

msgid "The status will revert to <strong>PENDING</strong>."
msgstr "O estado voltará para <strong>PENDENTE</strong>."

msgid "<strong>%(count)s</strong> payslips/results will be deleted."
msgstr "<strong>%(count)s</strong> recibos/resultados serão eliminados."

msgid "Totals (Gross: %(gross)s, Net: %(net)s) will be cleared."
msgstr "Totais (Bruto: %(gross)s, Líquido: %(net)s) serão limpos."

msgid "Yes, Reset Period"
msgstr "Sim, Repor Período"

msgid "Reset Payroll - FY%(fy)s"
msgstr "Repor Folha - AF%(fy)s"

msgid "Confirm Payroll Reset"
msgstr "Confirmar Reposição da Folha"

msgid "You are about to reset Fiscal Year %(fy)s"
msgstr "Está prestes a repor o Ano Fiscal %(fy)s"

msgid ""
"This action affects <strong>%(period_count)s</strong> payroll period linked "
"to this year."
msgstr ""
"Esta ação afeta <strong>%(period_count)s</strong> período de payroll "
"associado a este ano."

msgid ""
"This action affects <strong>%(period_count)s</strong> payroll periods linked "
"to this year."
msgstr ""
"Esta ação afeta <strong>%(period_count)s</strong> períodos de payroll "
"associados a este ano."

msgid "Warning:"
msgstr "Aviso:"

msgid "All periods will be reverted to <strong>PENDING</strong> status."
msgstr "Todos os períodos voltarão ao estado <strong>PENDENTE</strong>."

msgid ""
"All calculated results (Gross, Net, Tax) will be <strong>DELETED</strong>."
msgstr ""
"Todos os resultados calculados (Bruto, Líquido, Imposto) serão "
"<strong>ELIMINADOS</strong>."

msgid "The payroll status will be set to <strong>RUNNING</strong>."
msgstr "O estado da folha será definido como <strong>EM EXECUÇÃO</strong>."

msgid "This action <strong>cannot be undone</strong>."
msgstr "Esta ação <strong>não pode ser desfeita</strong>."

msgid "Yes, Reset Everything"
msgstr "Sim, Repor Tudo"

msgid "ID: %(pid)s | Company ID: %(cid)s | Requested by: %(email)s"
msgstr "ID: %(pid)s | ID da Empresa: %(cid)s | Solicitado por: %(email)s"

