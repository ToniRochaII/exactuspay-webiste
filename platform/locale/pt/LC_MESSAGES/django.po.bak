#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Upload Companies | ExactusPay"
msgstr "Subir Empresas | ExactusPay"

#: Exactus/company/templates/companies/upload_companies.html:1
#, python-format
msgid "Upload Companies — %(country)s"
msgstr "Subir Empresas — %(country)s"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Upload Companies"
msgstr "Subir Empresas"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Upload multiple companies via CSV file."
msgstr "Subir várias empresas via arquivo CSV."

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "CSV Requirements"
msgstr "Requisitos do CSV"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "File must be a .csv (comma-separated values)"
msgstr "O arquivo deve ser .csv (valores separados por vírgula)"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "The first row must contain column headers"
msgstr "A primeira linha deve conter os cabeçalhos das colunas"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Required columns:"
msgstr "Colunas obrigatórias:"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "country_code, company_code, trade_name, legal_name"
msgstr "country_code, company_code, trade_name, legal_name"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "country_code must match ISO2 codes (e.g., US, GB, FR)"
msgstr "country_code deve corresponder aos códigos ISO2 (ex.: US, GB, FR)"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Optional columns may be left empty"
msgstr "Colunas opcionais podem ser deixadas em branco"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Need a sample?"
msgstr "Precisa de um exemplo?"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Download a CSV template to ensure correct structure."
msgstr "Baixe um modelo CSV para garantir a estrutura correta."

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Download Template"
msgstr "Baixar Modelo"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Upload CSV File"
msgstr "Subir Arquivo CSV"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Validate without saving to the database."
msgstr "Validar sem salvar no banco de dados."

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Expected CSV Format (Example):"
msgstr "Formato CSV Esperado (Exemplo):"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Type"
msgstr "Tipo"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Description"
msgstr "Descrição"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "ISO2 country code (must match an active country)"
msgstr "Código ISO2 do país (deve corresponder a um país ativo)"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Unique per country"
msgstr "Único por país"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Commercial name of the company"
msgstr "Nome comercial da empresa"

#: Exactus/company/templates/companies/upload_companies.html:1
msgid "Registered legal entity name"
msgstr "Nome legal registrado da entidade"

