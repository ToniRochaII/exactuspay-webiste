#: templates/homepage.html:121
msgid "Compliance Status"
msgstr "Hali ya Uzingatiaji"

#: templates/homepage.html:123
msgid "All Systems Go"
msgstr "Mifumo Yote Iko Tayari"

#: templates/homepage.html:124
msgid "100% compliance across all active jurisdictions with automated updates."
msgstr "Uzingatiaji wa 100% katika mamlaka zote zinazotumika kwa masasisho ya kiotomatiki."

#: templates/homepage.html:129
msgid "Payment Processing"
msgstr "Uchakataji wa Malipo"

#: templates/homepage.html:131
msgid "Batch Ready"
msgstr "Tayari kwa Kundi"

#: templates/homepage.html:132
msgid "Process payments in multiple currencies with automated reconciliation."
