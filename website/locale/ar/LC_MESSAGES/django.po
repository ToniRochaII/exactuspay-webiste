msgstr "إعداد آمن للانضمام والوصول يتماشى مع هيكلك التنظيمي."

#: home/templates/home/security.html:891
msgid "Credential controls"
msgstr "ضوابط بيانات الاعتماد"

#: home/templates/home/security.html:892
msgid ""
"MFA, strong password policies, and least-privilege access baked into daily "
